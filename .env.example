# ─────────────────────────────────────────────────────────────
# Contact form (Web3Forms) — required for /api/contact to send email
# Create this in Vercel → Project → Settings → Environment Variables
# (and in a local .env.local for development). Never commit real values.
# ─────────────────────────────────────────────────────────────

# Web3Forms access key — get a free one at https://web3forms.com (enter the
# email that should receive submissions; no domain or credit card required).
# Submissions are delivered to the inbox tied to this key.
WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
