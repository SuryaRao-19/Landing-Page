# ─────────────────────────────────────────────────────────────
# Contact form (/api/contact) — a submission succeeds as long as it lands in
# at least one sink below. Configure Supabase, Web3Forms, or both.
# Create these in Vercel → Project → Settings → Environment Variables
# (and in a local .env.local for development). Never commit real values.
# ─────────────────────────────────────────────────────────────

# Supabase (PRIMARY sink) — persists each submission to a Postgres table,
# browsable at /admin/submissions. Find both values in
# Supabase → Project Settings → API. The service-role key bypasses Row Level
# Security — keep it server-side only and NEVER prefix it with NEXT_PUBLIC_.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web3Forms (OPTIONAL) — emails each submission as a best-effort notification.
# Get a free key at https://web3forms.com (enter the destination email; no
# domain or credit card required). A failed/unset key never blocks a submission
# that was stored in Supabase. Leave unset to skip email entirely.
WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Admin view (OPTIONAL) — HTTP Basic Auth for /admin/submissions,
# where stored submissions can be browsed. The page is LOCKED until
# ADMIN_PASSWORD is set: with no password, every /admin request is denied.
# ADMIN_USER defaults to "admin" if omitted. Use a long, random password.
# ─────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-a-long-random-string
