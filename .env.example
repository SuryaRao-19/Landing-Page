# ─────────────────────────────────────────────────────────────
# Contact form (Web3Forms) — required for /api/contact to send email
# Create this in Vercel → Project → Settings → Environment Variables
# (and in a local .env.local for development). Never commit real values.
# ─────────────────────────────────────────────────────────────

# Web3Forms access key — get a free one at https://web3forms.com (enter the
# email that should receive submissions; no domain or credit card required).
# Submissions are delivered to the inbox tied to this key.
WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Supabase (OPTIONAL) — persists contact submissions to a Postgres table
# in addition to emailing them. Leave unset to skip DB storage entirely;
# the contact form still works via Web3Forms.
#
# Find both values in Supabase → Project Settings → API.
# The service-role key bypasses Row Level Security — keep it server-side only
# and NEVER prefix it with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Admin view (OPTIONAL) — HTTP Basic Auth for /admin/submissions,
# where stored submissions can be browsed. The page is LOCKED until
# ADMIN_PASSWORD is set: with no password, every /admin request is denied.
# ADMIN_USER defaults to "admin" if omitted. Use a long, random password.
# ─────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-a-long-random-string
