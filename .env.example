# ─────────────────────────────────────────────────────────────
# Contact form (Resend) — required for /api/contact to send email
# Create these in Vercel → Project → Settings → Environment Variables
# (and in a local .env.local for development). Never commit real values.
# ─────────────────────────────────────────────────────────────

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered
CONTACT_TO_EMAIL=hello@nexgenit.in

# Verified sender. For production this must be an address on a domain you have
# verified in Resend (https://resend.com/domains). For quick testing you can use
# onboarding@resend.dev, which only delivers to your own Resend account email.
CONTACT_FROM_EMAIL=NexGen Website <noreply@nexgenit.in>
